-- Animasi warna saat load (merah -> warna asli theme)
task.spawn(function()
    local StartColor = Color3.fromRGB(255, 65, 65)
    local ColorKeys = {
        "BackgroundColor", "MainColor", "AccentColor", "OutlineColor",
        "FontColor", "Red", "Dark", "White",
    }
    local TargetColors = {}
    for _, Key in ipairs(ColorKeys) do
        if typeof(Library.Scheme[Key]) == "Color3" then
            TargetColors[Key] = Library.Scheme[Key]
        end
    end
    for Key in pairs(TargetColors) do
        Library.Scheme[Key] = StartColor
    end
    Library:UpdateColorsUsingRegistry()

    local Duration = 2.5
    local Elapsed = 0
    while Elapsed < Duration do
        local dt = RunService.RenderStepped:Wait()
        Elapsed += dt
        local Alpha = math.clamp(Elapsed / Duration, 0, 1)
        for Key, Target in pairs(TargetColors) do
            Library.Scheme[Key] = StartColor:Lerp(Target, Alpha)
        end
        Library:UpdateColorsUsingRegistry()
    end
    for Key, Target in pairs(TargetColors) do
        Library.Scheme[Key] = Target
    end
    Library:UpdateColorsUsingRegistry()
end)

