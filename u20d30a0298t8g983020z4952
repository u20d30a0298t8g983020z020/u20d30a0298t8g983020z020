-- Fungsi untuk mencari fungsi berdasarkan nama di garbage collector
local function SearchGc(FunctionName)
    for _, v in pairs(getgc()) do
        if type(v) == "function" then
            local info = debug.getinfo(v)
            if info.name == FunctionName then
                return v
            end
        end
    end
end

local CastBlacklist = SearchGc("CastBlacklist")
local CastWhitelist = SearchGc("CastWhitelist")
local OldCastBlacklist

local function IsValidTarget(Player)
    if not Player or Player == LocalPlayer then
        return false
    end
    local Character = Player.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local Head = Character and Character:FindFirstChild("Head")
    return Humanoid and Head and Humanoid.Health > 0
end

local function GetSelectedTarget()
    if not SilentAimConfig.Enabled then
        return nil
    end
    Camera = Workspace.CurrentCamera or Camera
    local MousePosition = UserInputService:GetMouseLocation()
    local Radius = FOVConfig.Enabled and (FOVConfig.Radius * 10) or math.huge
    local ClosestPlayer
    local ClosestDistance = math.huge

    for _, Player in ipairs(Players:GetPlayers()) do
        if IsValidTarget(Player) then
            local Head = Player.Character.Head
            local ScreenPosition, OnScreen = Camera:WorldToViewportPoint(Head.Position)
            if OnScreen then
                local Distance = (Vector2.new(ScreenPosition.X, ScreenPosition.Y) - MousePosition).Magnitude
                if Distance <= Radius and Distance < ClosestDistance then
                    ClosestDistance = Distance
                    ClosestPlayer = Player
                end
            end
        end
    end
    return ClosestPlayer
end

local function CreateTargetVisuals()
    if typeof(Drawing) == "table" and not Snapline then
        Snapline = Drawing.new("Line")
        Snapline.Visible = false
        Snapline.Color = Color3.new(1, 1, 1)
        Snapline.Thickness = 1
    end
    if not TargetHighlight then
        local Parent = gethui and gethui() or game:GetService("CoreGui")
        TargetHighlight = Instance.new("Highlight")
        TargetHighlight.FillColor = Color3.fromRGB(255, 0, 0)
        TargetHighlight.FillTransparency = 0.6
        TargetHighlight.OutlineTransparency = 1
        TargetHighlight.Enabled = false
        TargetHighlight.Parent = Parent
    end
end

local function HideTargetVisuals()
    if Snapline then Snapline.Visible = false end
    if TargetHighlight then
        TargetHighlight.Adornee = nil
        TargetHighlight.Enabled = false
    end
end

local function UpdateTargetVisuals()
    if not SilentAimConfig.Enabled
        or (not TargetVisualConfig.Snapline and not TargetVisualConfig.Highlight) then
        HideTargetVisuals()
        return
    end
    CreateTargetVisuals()
    if not CurrentTarget or not CurrentTarget.Character then
        HideTargetVisuals()
        return
    end
    local Head = CurrentTarget.Character:FindFirstChild("Head")
    if not Head then
        HideTargetVisuals()
        return
    end
    Camera = Workspace.CurrentCamera or Camera
    local TargetPosition, OnScreen = Camera:WorldToViewportPoint(Head.Position)
    local MousePosition = UserInputService:GetMouseLocation()
    if Snapline then
        Snapline.Visible = TargetVisualConfig.Snapline and OnScreen
        Snapline.From = MousePosition
        Snapline.To = Vector2.new(TargetPosition.X, TargetPosition.Y)
    end
    if TargetHighlight then
        TargetHighlight.Adornee = TargetVisualConfig.Highlight and CurrentTarget.Character or nil
        TargetHighlight.Enabled = TargetVisualConfig.Highlight
    end
end

local function CreateFOVDrawings()
    if FOVCircle or typeof(Drawing) ~= "table" then return end
    FOVOutline = Drawing.new("Circle")
    FOVOutline.Visible = false
    FOVOutline.Color = Color3.new(0, 0, 0)
    FOVOutline.Thickness = 4
    FOVOutline.NumSides = FOVConfig.Sides

    FOVCircle = Drawing.new("Circle")
    FOVCircle.Visible = false
    FOVCircle.Color = Color3.new(1, 1, 1)
    FOVCircle.Thickness = 2
    FOVCircle.NumSides = FOVConfig.Sides
end

local function HideFOV()
    if FOVCircle then FOVCircle.Visible = false end
    if FOVOutline then FOVOutline.Visible = false end
end

local function UpdateFOV()
    if not SilentAimConfig.Enabled or not FOVConfig.Draw then
        HideFOV()
        return
    end
    CreateFOVDrawings()
    if not FOVCircle or not FOVOutline then return end
    Camera = Workspace.CurrentCamera or Camera
    local MousePosition = UserInputService:GetMouseLocation()
    local Radius = FOVConfig.Radius * 10
    FOVCircle.Visible = true
    FOVCircle.Position = MousePosition
    FOVCircle.Radius = Radius
    FOVCircle.NumSides = FOVConfig.Sides
    FOVOutline.Visible = true
    FOVOutline.Position = MousePosition
    FOVOutline.Radius = Radius
    FOVOutline.NumSides = FOVConfig.Sides
end

