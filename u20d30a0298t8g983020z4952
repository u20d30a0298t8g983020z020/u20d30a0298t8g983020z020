local function GetRandomHitPart(Character)
    local parts = SilentAimConfig.HitParts
    if #parts == 0 then return Character:FindFirstChild("Head") end
    local tryPart = parts[math.random(1, #parts)]
    return Character:FindFirstChild(tryPart) or Character:FindFirstChild("Head")
end

if CastBlacklist and CastWhitelist then
    -- Hook menggunakan CastBlacklist / CastWhitelist (metode utama)
    OldCastBlacklist = hookfunction(CastBlacklist, function(...)
        local args = {...}
        local Target = CurrentTarget
        if SilentAimConfig.Enabled and Target and Target.Character then
            if math.random(0, 100) <= SilentAimConfig.HitChance then
                local TargetPart = GetRandomHitPart(Target.Character)
                if TargetPart and typeof(args[1]) == "Vector3" then
                    -- Ubah arah tembakan ke target part
                    args[2] = TargetPart.Position - args[1]
                    if SilentAimConfig.Wallbang then
                        -- Wallbang: ganti tabel whitelist dengan karakter target
                        args[3] = {Target.Character}
                        return CastWhitelist(unpack(args))
                    end
                    return OldCastBlacklist(unpack(args))
                end
            end
        end
        return OldCastBlacklist(...)
    end)
else
    -- Fallback: hook __namecall pada Raycast (metode generic)
    local HookInstalled = false
    local GameMetatable
    local OldNamecall
    if type(getrawmetatable) == "function" then
        GameMetatable = getrawmetatable(game)
        OldNamecall = GameMetatable.__namecall
        local FindFirstChild = Workspace.FindFirstChild

        setreadonly(GameMetatable, false)
        GameMetatable.__namecall = newcclosure(function(Self, ...)
            local Arguments = {...}
            local Method = getnamecallmethod()
            if Method == "Raycast" and SilentAimConfig.Enabled and not checkcaller() then
                local Target = CurrentTarget
                if Target and Target.Character and math.random(0, 100) <= SilentAimConfig.HitChance then
                    local TargetPart = GetRandomHitPart(Target.Character)
                    if TargetPart and typeof(Arguments[1]) == "Vector3" then
                        Arguments[2] = (TargetPart.Position - Arguments[1]).Unit * 1000
                        if SilentAimConfig.Wallbang then
                            return {
                                Instance = TargetPart,
                                Position = TargetPart.Position,
                                Distance = (TargetPart.Position - Arguments[1]).Magnitude,
                                Material = Enum.Material.SmoothPlastic,
                                Normal = Vector3.zero,
                            }
                        end
                        return OldNamecall(Self, table.unpack(Arguments))
                    end
                end
            end
            return OldNamecall(Self, ...)
        end)
        setreadonly(GameMetatable, true)
        HookInstalled = true

        -- Bersihkan hook saat unload
        local oldUnload = Library.OnUnload or function() end
        Library.OnUnload = function(...)
            if HookInstalled and GameMetatable then
                setreadonly(GameMetatable, false)
                GameMetatable.__namecall = OldNamecall
                setreadonly(GameMetatable, true)
            end
            oldUnload(...)
        end
    end
end

