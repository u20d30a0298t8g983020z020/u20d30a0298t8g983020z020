local function updateDiscordProfile(Window, discordID)
    if not discordID or discordID == "0" or discordID == "" then
        return
    end

    task.spawn(function()
        local success, response = pcall(function()
            return game:HttpGet("https://discord-lookup-api-neon.vercel.app/v1/user/" .. discordID)
        end)
        
        if success and response then
            local data = HttpService:JSONDecode(response)
            if data and data.global_name then
                if Window.Items and Window.Items["Username"] then
                    Window.Items["Username"].Instance.Text = data.global_name
                end
                
                if data.avatar and data.avatar.link then
                    local ext = data.avatar.is_animated and ".gif" or ".png"
                    local filePath = "lds13/Assets/Profiles/" .. discordID .. ext
                    
                    if not isfolder("lds13/Assets") then makefolder("lds13/Assets") end
                    if not isfolder("lds13/Assets/Profiles") then makefolder("lds13/Assets/Profiles") end
                    
                    local dlSuccess, imgData = pcall(function()
                        return game:HttpGet(data.avatar.link)
                    end)
                    
                    if dlSuccess and imgData then
                        writefile(filePath, imgData)
                        if Window.Items and Window.Items["AvatarIcon"] then
                            Window.Items["AvatarIcon"].Instance.Image = getcustomasset(filePath)
                        end
                    end
                end
            end
        end
    end)
end

