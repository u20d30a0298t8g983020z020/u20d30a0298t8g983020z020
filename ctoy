    VisualConfig.Draw_Snapline = State
end}):Colorpicker({Name="Snapline Color",Default = Color3.new(1,1,1), Alpha=0,Callback=function(Color,Transparency)
    VisualConfig.SnaplineColor = Color
    VisualConfig.SnaplineTransparency = Transparency
end})

SelectedTarget_Settings:Slider({Name="Snapline Thickness",Flag="Snapline_Thickness",Default=2,Min=1,Max=5,Callback=function(State)
    VisualConfig.SnaplineThickness = State
end})

local _Toggle=SelectedTarget_Settings:Toggle({Name="Highlight Target",Flag="Highlight_Target",Callback=function(State) end})
_Toggle:Colorpicker({Name="Highlight Filled Color", Default = Color3.fromRGB(255,0,0), Alpha=0.6,Callback=function(Color,Transparency)
    VisualConfig.HighlightColor = Color
    VisualConfig.HighlightTransparency = Transparency
end})

-- Hitbox Customization
local HitBoxExpander_Section = CombatPage:Section({Name = "Hit-Box Customization", Icon = "131145598162617", Side = 1})

HitBoxExpander_Section:Toggle({Name = "Enabled", Flag = "HitBoxes_Enabled", Default = false, Callback = function(State)
    HitboxConfig.Enabled = State
end})

HitBoxExpander_Section:Toggle({Name = "Safe-Zone Check", Flag = "HitBoxes_SafeZoneCheck", Default = false, Callback = function(State)
    HitboxConfig.SafeZoneCheck = State
end})

HitBoxExpander_Section:Slider({Name = "Multiplier", Flag = "HitBoxes_Multiplier", Max = 50, Min = 1, Default = 5, Suffix = "x", Callback = function(State)
    HitboxConfig.Multiplier = State
end})

HitBoxExpander_Section:Label("Hit-Box Color"):Colorpicker({
    Name = "Hit-Box Color",
    Flag = "HitBoxes_Color",
    Default = Color3.new(1,1,1),
    Alpha = 0,
    Callback = function(Value)
        HitboxConfig.Color = Value
    end
})

HitBoxExpander_Section:Slider({Name = "Hit-Box Transparency", Flag = "HitBoxes_Transparency", Min = 0, Max = 100, Default = 75, Suffix = "%", Callback = function(State)
    HitboxConfig.Transparency = State / 100
end})

