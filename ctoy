RunService:BindToRenderStep("SilentAimESP", 1, function()
    for Player, Object in pairs(ESPObjects) do
        HideESP(Object)

        if not ESPConfig.Enabled or table.find(Friends, Player.Name) then continue end

        local Character = Player.Character
        local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
        local Root = Character and Character:FindFirstChild("HumanoidRootPart")
        local Head = Character and Character:FindFirstChild("Head")
        if not Humanoid or not Root or not Head or Humanoid.Health <= 0 then continue end

        local Distance = (Camera.CFrame.Position - Root.Position).Magnitude
        if Distance > ESPConfig.RenderDistance then continue end

        local Top, TopVisible = Camera:WorldToViewportPoint(Head.Position + Vector3.new(0, 0.5, 0))
        local Bottom, BottomVisible = Camera:WorldToViewportPoint(Root.Position - Vector3.new(0, 3, 0))
        if not TopVisible and not BottomVisible then continue end

        local Height = math.abs(Bottom.Y - Top.Y)
        if Height < 2 then continue end
        local Width = Height * 0.55
        local Left, Right = Top.X - Width / 2, Top.X + Width / 2
        local TopY, BottomY = Top.Y, Bottom.Y

        if ESPConfig.Boxes then
            Object.Box[1].From, Object.Box[1].To = Vector2.new(Left, TopY), Vector2.new(Right, TopY)
            Object.Box[2].From, Object.Box[2].To = Vector2.new(Right, TopY), Vector2.new(Right, BottomY)
            Object.Box[3].From, Object.Box[3].To = Vector2.new(Right, BottomY), Vector2.new(Left, BottomY)
            Object.Box[4].From, Object.Box[4].To = Vector2.new(Left, BottomY), Vector2.new(Left, TopY)
            for _, Line in pairs(Object.Box) do Line.Color, Line.Visible = ESPConfig.BoxColor, true end
        end

        if ESPConfig.Names then
            Object.Name.Text = Player.DisplayName or Player.Name
            Object.Name.Position = Vector2.new(Top.X, TopY - 16)
            Object.Name.Color, Object.Name.Visible = ESPConfig.NameColor, true
        end

        if ESPConfig.Distance then
            Object.Distance.Text = string.format("[%dm]", math.floor(Distance))
            Object.Distance.Position = Vector2.new(Top.X, BottomY + 2)
            Object.Distance.Color, Object.Distance.Visible = ESPConfig.DistanceColor, true
        end

        if ESPConfig.Weapon then
            local Tool = Character:FindFirstChildOfClass("Tool")
            if Tool then
                Object.Weapon.Text = "[" .. Tool.Name .. "]"
                Object.Weapon.Position = Vector2.new(Top.X, BottomY + (ESPConfig.Distance and 17 or 2))
                Object.Weapon.Color, Object.Weapon.Visible = ESPConfig.WeaponColor, true
            end
        end

        if ESPConfig.Healthbar then
            local Ratio = math.clamp(Humanoid.Health / math.max(Humanoid.MaxHealth, 1), 0, 1)
            local X = Left - 5
            Object.HealthOutline.From, Object.HealthOutline.To = Vector2.new(X, BottomY), Vector2.new(X, TopY)
            Object.Health.From, Object.Health.To = Vector2.new(X, BottomY), Vector2.new(X, BottomY - Height * Ratio)
            Object.Health.Color = Color3.fromRGB(255 - math.floor(255 * Ratio), math.floor(255 * Ratio), 0)
            Object.HealthOutline.Visible, Object.Health.Visible = true, true
        end
    end
end)

