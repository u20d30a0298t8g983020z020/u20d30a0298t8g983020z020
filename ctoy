local game_metatable = getrawmetatable(game)
setreadonly(game_metatable, false)

local __index_hook = game_metatable.__index
local __namecall_hook = game_metatable.__namecall

game_metatable.__index = newcclosure(function(Self, Index)
    if typeof(Self) == "Instance" then
        if Index == "Size" and Self.Name == "Head" and OriginalHeadSizes[Self] then
            return OriginalHeadSizes[Self]
        end

        if Index == "CanCollide" and OriginalCanCollide[Self] ~= nil then
            return OriginalCanCollide[Self]
        end
    end

    return __index_hook(Self, Index)
end)

game_metatable.__namecall = newcclosure(function(Self, ...)
    local Arguments = {...}
    local Method = getnamecallmethod()

    if Method == "Raycast" and SilentConfig.Enabled then
        if checkcaller() then
            return __namecall_hook(Self, ...)
        end

        local Script = getcallingscript()

        if Script and Script.Name:find("?") then
            return __namecall_hook(Self, ...)
        end

        local Traceback = debug.traceback()

        if Traceback:find("Move") then
            return __namecall_hook(Self, ...)
        end

        if Traceback:find("MouseHover") then
            return __namecall_hook(Self, ...)
        end

        if Traceback:find("isWallInFront") then 
            return __namecall_hook(Self, ...)
        end
        
        if SilentConfig.Enabled then
            if not (math.random(0, 100) <= SilentConfig.HitChance) then
                return __namecall_hook(Self, ...)
            end

            local TargetPart

            if Target and Target.Character then
                TargetPart = FindFirstChild(Target.Character, SilentConfig.HitParts[1] and SilentConfig.HitParts[math.random(1, #SilentConfig.HitParts)] or "Head")

                if not TargetPart then
                    return __namecall_hook(Self, ...)
                end

                local Origin = Arguments[1]
                if typeof(Origin) ~= "Vector3" then
                    return __namecall_hook(Self, ...)
                end
                local Direction = (TargetPart.Position - Origin).Unit * 1000
                
                Arguments[2] = Direction
            end

            if SilentConfig.WallBang and Target and Target.Character and TargetPart then
                return {
                    Instance = TargetPart,
                    Position = TargetPart.Position,
                    Distance = (TargetPart.Position - Arguments[1]).Magnitude,
                    Material = Enum.Material.SmoothPlastic,
                    Normal = Vector3.zero,
                }
            end

            return __namecall_hook(Self, unpack(Arguments))
        end
    end

    return __namecall_hook(Self, ...)
end)

setreadonly(game_metatable, true)

