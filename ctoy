local ESPObjects = {}

local function NewESPObject(Class, Properties)
    local Object = Drawing.new(Class)
    for Index, Value in pairs(Properties) do
        Object[Index] = Value
    end
    return Object
end

local function CreateESP(Player)
    if ESPObjects[Player] then return ESPObjects[Player] end

    local Object = {
        Box = {},
        Name = NewESPObject("Text", {Visible = false, Center = true, Outline = true, Size = 13, Color = ESPConfig.Color}),
        Distance = NewESPObject("Text", {Visible = false, Center = true, Outline = true, Size = 13, Color = ESPConfig.Color}),
        Weapon = NewESPObject("Text", {Visible = false, Center = true, Outline = true, Size = 13, Color = ESPConfig.Color}),
        Health = NewESPObject("Line", {Visible = false, Thickness = 2, Color = Color3.fromRGB(0, 255, 0)}),
        HealthOutline = NewESPObject("Line", {Visible = false, Thickness = 4, Color = Color3.new(0, 0, 0)}),
    }

    for Index = 1, 4 do
        Object.Box[Index] = NewESPObject("Line", {Visible = false, Thickness = 1, Color = ESPConfig.Color})
    end

    ESPObjects[Player] = Object
    return Object
end

local function HideESP(Object)
    for _, Line in pairs(Object.Box) do Line.Visible = false end
    Object.Name.Visible = false
    Object.Distance.Visible = false
    Object.Weapon.Visible = false
    Object.Health.Visible = false
    Object.HealthOutline.Visible = false
end

local function RemoveESP(Player)
    local Object = ESPObjects[Player]
    if not Object then return end
    HideESP(Object)
    for _, Line in pairs(Object.Box) do Line:Remove() end
    Object.Name:Remove()
    Object.Distance:Remove()
    Object.Weapon:Remove()
    Object.Health:Remove()
    Object.HealthOutline:Remove()
    ESPObjects[Player] = nil
end

for _, Player in ipairs(Players:GetPlayers()) do
