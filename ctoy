local function GetSelectedTarget()
    if Device_Mobile then
        TargetSelector.Targetting = SilentConfig.Enabled
    end

    if not SilentConfig.Enabled and not VisualConfig.Draw_Snapline then
        Target = nil
        return nil
    end

    local PlayersList = Players:GetPlayers()
    local MouseLocation = Device_Mobile and Center_Of_Screen or UserInputService:GetMouseLocation()
    local Radius = TargetSelector.UseFOV and (Library.Flags["FieldOfView_Radius"] or 25) * 10 or math.huge

    local ClosestPlayer = nil
    local ClosestDistance = math.huge

    for _, Player in ipairs(PlayersList) do
        if Player == LocalPlayer then continue end
        if table.find(Friends, Player.Name) then continue end

        local Character = Player.Character
        if not Character then continue end

        local Humanoid = Character:FindFirstChild("Humanoid")
        local Head = Character:FindFirstChild("Head")

        if not Humanoid or not Head or Humanoid.Health <= 0 then continue end

        -- Use WorldToViewportPoint so it aligns properly with GetMouseLocation()
        local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Head.Position)
        if not OnScreen then continue end

        local Distance = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MouseLocation).Magnitude
        if Distance > Radius then continue end

        if TargetSelector.VisibleCheck and not SilentConfig.WallBang then
            if not WallCheck(Character) then continue end
        end

        if TargetSelector.HealthCheck and Humanoid.Health < TargetSelector.Health then continue end
        if TargetSelector.FriendCheck and table.find(Friends, Player.Name) then continue end
        if TargetSelector.LimitDistance and not DistanceCheck(Player, TargetSelector.MaxDistance) then continue end
        if TargetSelector.ProtectedCheck and InsideSafezone(Player) then continue end

        if Distance < ClosestDistance then
            ClosestDistance = Distance
            ClosestPlayer = Player
        end
    end

    Target = ClosestPlayer
    return Target
end

